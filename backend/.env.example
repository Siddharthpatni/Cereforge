# Application
APP_NAME=NeuralForge
APP_ENV=development           # development | production
APP_SECRET_KEY=change-me-to-a-64-char-random-string-in-production-please-now
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# Database
DATABASE_URL=postgresql+asyncpg://neuralforge:neuralforge@localhost:5432/neuralforge
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-different-64-char-random-string-for-jwt-tokens
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# AI (Anthropic) — required for AI Mentor feature
ANTHROPIC_API_KEY=

# Email (optional — disable email verification if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@neuralforge.io
EMAILS_FROM_NAME=NeuralForge

# Storage (optional — disable avatar upload if not set)
S3_BUCKET_NAME=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Monitoring (optional)
SENTRY_DSN=
